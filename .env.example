#social-media-rag-env

# OpenAI API Key (Required for live GPT-4o chat and Whisper Reel transcripts)
# If empty, the backend will dynamically run high-fidelity simulations for easy testing!
OPENAI_API_KEY=your_openai_api_key_here

# Core Configuration
DATABASE_URL=sqlite:///./videos.db
VECTOR_DB_MODE=sqlite

# Models
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
